{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmontage/artifacts/narration_timeline",
  "title": "Narration Timeline",
  "type": "object",
  "required": ["version", "source_sha256", "total_duration_ms", "units"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "source_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "total_duration_ms": { "type": "integer", "minimum": 1 },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "source_text", "source_start_char", "source_end_char", "audio_asset_id", "audio_path", "actual_duration_ms", "words", "visual_beats"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source_text": { "type": "string", "minLength": 1 },
          "source_start_char": { "type": "integer", "minimum": 0 },
          "source_end_char": { "type": "integer", "minimum": 1 },
          "audio_asset_id": { "type": "string", "minLength": 1 },
          "audio_path": { "type": "string", "minLength": 1 },
          "actual_duration_ms": { "type": "integer", "minimum": 1 },
          "words": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["text", "start_ms", "end_ms"],
              "properties": {
                "text": { "type": "string", "minLength": 1 },
                "start_ms": { "type": "integer", "minimum": 0 },
                "end_ms": { "type": "integer", "minimum": 1 }
              },
              "additionalProperties": false
            }
          },
          "visual_beats": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "start_ms", "end_ms", "visual_intent"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "start_ms": { "type": "integer", "minimum": 0 },
                "end_ms": { "type": "integer", "minimum": 1 },
                "visual_intent": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
