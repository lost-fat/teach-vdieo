{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmontage/artifacts/scene_plan",
  "title": "Scene Plan",
  "description": "Ordered scene list produced by the Scene Planner agent.",
  "type": "object",
  "required": ["version", "scenes"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "style_playbook": { "type": "string", "description": "Name of the active style playbook" },
    "narrative_units": {
      "type": "array",
      "description": "Meaning-level source units. They guide timing and teaching structure but do not force one generated clip per unit.",
      "items": {
        "type": "object",
        "required": ["id", "source_text", "start_seconds", "end_seconds", "discourse_role"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source_text": { "type": "string", "minLength": 1 },
          "start_seconds": { "type": "number", "minimum": 0 },
          "end_seconds": { "type": "number", "minimum": 0 },
          "discourse_role": {
            "type": "string",
            "enum": ["setting", "movement", "comparison", "cause_effect", "process", "historical_event", "abstract_concept", "dialogue", "transition"]
          }
        },
        "additionalProperties": false
      }
    },
    "visual_story_arc": {
      "type": "object",
      "description": "Whole-article dramatic design. Source units supply evidence to this arc; they are not one-to-one shot requests.",
      "required": ["theme", "visual_premise", "story_carrier", "opening_state", "turning_point", "closing_state", "recurring_motif", "chapters"],
      "properties": {
        "theme": { "type": "string", "minLength": 1 },
        "visual_premise": { "type": "string", "minLength": 1 },
        "story_carrier": {
          "type": "object",
          "description": "A recurring person, object, place, process, question, motif, or ensemble whose changing state carries the visual story.",
          "required": ["id", "kind", "description"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": {
              "type": "string",
              "enum": ["person", "object", "place", "process", "question", "motif", "ensemble"]
            },
            "description": { "type": "string", "minLength": 1 },
            "continuity_ref": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "opening_state": { "type": "string", "minLength": 1 },
        "turning_point": { "type": "string", "minLength": 1 },
        "closing_state": { "type": "string", "minLength": 1 },
        "recurring_motif": { "type": "string", "minLength": 1 },
        "chapters": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["id", "role", "narrative_unit_ids", "objective", "entry_state", "exit_state"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "role": {
                "type": "string",
                "enum": ["hook", "setup", "tension", "turning_point", "development", "payoff", "reflection"]
              },
              "narrative_unit_ids": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 1,
                "uniqueItems": true
              },
              "objective": { "type": "string", "minLength": 1 },
              "entry_state": { "type": "string", "minLength": 1 },
              "exit_state": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "continuity_bible": {
      "type": "object",
      "description": "Article-level visual invariants reused by every scene and provider prompt.",
      "required": ["entities", "locations", "period", "style", "camera_rules", "prohibited_elements"],
      "properties": {
        "entities": {
          "type": "array",
          "items": { "$ref": "#/$defs/continuitySubject" }
        },
        "locations": {
          "type": "array",
          "items": { "$ref": "#/$defs/continuitySubject" }
        },
        "period": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["id", "label", "immutable_traits"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "label": { "type": "string", "minLength": 1 },
                "immutable_traits": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 },
                  "uniqueItems": true
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "style": {
          "type": "object",
          "required": ["palette", "lighting", "texture"],
          "properties": {
            "palette": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1,
              "uniqueItems": true
            },
            "lighting": { "type": "string", "minLength": 1 },
            "texture": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "camera_rules": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "prohibited_elements": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "description", "start_seconds", "end_seconds"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["talking_head", "broll", "animation", "character_scene", "diagram", "text_card", "transition", "generated", "screen_recording"]
          },
          "description": { "type": "string" },
          "start_seconds": { "type": "number", "minimum": 0 },
          "end_seconds": { "type": "number", "minimum": 0 },
          "narrative_unit_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1,
            "uniqueItems": true,
            "description": "One scene may cover multiple adjacent meaning units when visual context remains continuous."
          },
          "visual_role": {
            "type": "string",
            "enum": ["setting", "movement", "comparison", "cause_effect", "process", "historical_event", "abstract_concept", "dialogue", "transition"]
          },
          "story_chapter_id": {
            "type": "string",
            "minLength": 1,
            "description": "Visual-story chapter advanced by this scene; chapters may span multiple provider clips."
          },
          "story_beat": {
            "type": "string",
            "enum": ["hook", "setup", "tension", "turning_point", "development", "payoff", "reflection"]
          },
          "story_contribution": {
            "type": "string",
            "minLength": 1,
            "description": "How the shot changes the whole visual story, not a paraphrase of its narration sentence."
          },
          "visual_mode": {
            "type": "string",
            "enum": ["direct_evidence", "interpretive", "metaphor", "bridge", "payoff"],
            "description": "Relationship between narrated facts and the chosen visual."
          },
          "visual_state_change": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string", "minLength": 1 },
              "to": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "continuity_from_scene_id": {
            "type": "string",
            "minLength": 1,
            "description": "Previous generated scene whose carrier, screen direction, or end frame should continue."
          },
          "match_action": {
            "type": "string",
            "minLength": 1,
            "description": "Action, shape, direction, or motif used to make a technical clip boundary feel continuous."
          },
          "video_prompt_spec": {
            "type": "object",
            "description": "Provider-neutral motion plan compiled into a model-specific prompt at generation time.",
            "required": ["single_shot", "subject_motion", "camera_motion", "temporal_beats", "continuity_refs", "negative_constraints"],
            "properties": {
              "single_shot": { "type": "boolean" },
              "subject_motion": { "type": "string", "minLength": 1 },
              "camera_motion": { "type": "string", "minLength": 1 },
              "temporal_beats": {
                "type": "array",
                "minItems": 1,
                "description": "Ordered scene-local action times starting from zero, not absolute article timeline times.",
                "items": {
                  "type": "object",
                  "required": ["start_seconds", "end_seconds", "action"],
                  "properties": {
                    "start_seconds": { "type": "number", "minimum": 0 },
                    "end_seconds": { "type": "number", "minimum": 0 },
                    "action": { "type": "string", "minLength": 1 }
                  },
                  "additionalProperties": false
                }
              },
              "foreground_event": { "type": "string", "minLength": 1 },
              "visual_payoff": { "type": "string", "minLength": 1 },
              "continuity_refs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              },
              "caption_safe_area": { "type": "string", "minLength": 1 },
              "negative_constraints": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            },
            "additionalProperties": false
          },
          "script_section_id": { "type": "string" },
          "framing": { "type": "string" },
          "movement": { "type": "string" },
          "transition_in": { "type": "string" },
          "transition_out": { "type": "string" },
          "overlay_notes": { "type": "string" },
          "shot_language": {
            "type": "object",
            "description": "Structured cinematography vocabulary for this scene",
            "properties": {
              "shot_size": {
                "type": "string",
                "enum": ["extreme_wide", "wide", "medium_wide", "medium", "medium_close", "close_up", "extreme_close_up", "over_shoulder", "insert", "establishing"]
              },
              "camera_movement": {
                "type": "string",
                "enum": ["static", "pan_left", "pan_right", "tilt_up", "tilt_down", "dolly_in", "dolly_out", "tracking_left", "tracking_right", "crane_up", "crane_down", "handheld", "steadicam", "whip_pan", "orbital", "zoom_in", "zoom_out", "rack_focus"]
              },
              "lens_mm": { "type": "integer", "enum": [14, 24, 35, 50, 85, 135, 200] },
              "lighting_key": {
                "type": "string",
                "enum": ["high_key", "low_key", "natural", "golden_hour", "blue_hour", "tungsten_warm", "neon", "silhouette", "rim_lit", "volumetric", "overcast_soft"]
              },
              "depth_of_field": { "type": "string", "enum": ["shallow", "medium", "deep"] },
              "color_temperature": { "type": "string", "enum": ["cool", "neutral", "warm", "mixed"] }
            },
            "additionalProperties": false
          },
          "shot_intent": {
            "type": "string",
            "description": "WHY this shot exists — what purpose it serves in the video"
          },
          "narrative_role": {
            "type": "string",
            "enum": ["establish_context", "introduce_subject", "build_tension", "deliver_payload", "transition", "emotional_beat", "evidence", "comparison", "resolution", "call_to_action"],
            "description": "What role this scene plays in the narrative structure"
          },
          "information_role": {
            "type": "string",
            "description": "What the viewer learns or feels from this scene"
          },
          "hero_moment": {
            "type": "boolean",
            "default": false,
            "description": "True if this is the visual peak of the video — deserves extra attention"
          },
          "character_actions": {
            "type": "array",
            "description": "Character-specific acting beats for rigged character animation scenes",
            "items": {
              "type": "object",
              "required": ["character_id", "action_sequence"],
              "properties": {
                "character_id": { "type": "string" },
                "emotion": { "type": "string" },
                "action_sequence": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                },
                "dialogue": { "type": "string" },
                "target": { "type": "string" },
                "notes": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "texture_keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Visual texture descriptors: grain, clean, anamorphic, gritty, ethereal, etc."
          },
          "required_assets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "description": { "type": "string" },
                "source": { "type": "string", "enum": ["generate", "source", "provided", "record"] }
              },
              "required": ["type", "description", "source"]
            }
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "metadata": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "required": ["visual_story_arc"] },
      "then": {
        "properties": {
          "scenes": {
            "items": {
              "required": ["narrative_unit_ids", "story_chapter_id", "story_beat", "story_contribution", "visual_mode", "visual_state_change"]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "continuitySubject": {
      "type": "object",
      "required": ["id", "canonical_name", "immutable_traits"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "canonical_name": { "type": "string", "minLength": 1 },
        "translations": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "immutable_traits": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
